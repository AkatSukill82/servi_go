{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "onboarding_completed": {
      "type": "boolean",
      "default": false,
      "description": "True once the user has seen and dismissed the onboarding popup"
    }
  }
}